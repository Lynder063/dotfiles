{
  "layer": "top",
  "height": 30,
  "spacing": 0,
  "modules-left": [
    "hyprland/workspaces",
    "privacy"
  ],
  "modules-center": [
    "tray",
    "clock"
  ],
  "modules-right": [
    "power-profiles-daemon",
    "cpu",
    "memory",
    "backlight",
    "battery",
    "pulseaudio"
  ],
  "hyprland/workspaces": {},
  "hyprland/window": {
    "max-length": 130,
    "separate-outputs": true
  },
  "cpu": {
    "interval": 10,
    "format": "{usage}% ґ░НЫ",
    "max-length": 10
  },
  "tray": {
    "icon-size": 19,
    "spacing": 5
  },
  "memory": {
    "interval": 10,
    "format": "{used:0.1f}G юЙж"
  },
  "clock": {
    "interval": 1,
    "format": "яБ│ {:%d.%m.%y яАЧ %H:%M}",
    "locale": "cs_CZ.UTF-8",
    "tooltip-format": "<span size= '10pt' font='Hack Nerd Font'>{calendar}</span>",
    "calendar": {
      "mode": "month",
      "mode-mon-col": 3,
      "weeks-pos": "right",
      "on-scroll": 1,
      "format": {
        "months": "<span color='#ffead3'><b>{}</b></span>",
        "days": "<span color='#ecc6d9'><b>{}</b></span>",
        "weeks": "<span color='#99ffdd'><b>W{}</b></span>",
        "weekdays": "<span color='#ffcc66'><b>{}</b></span>",
        "today": "<span color='#ff6699'><b><u>{}</u></b></span>"
      }
    },
    "actions": {
      "on-click-right": "mode",
      "on-click-forward": "tz_up",
      "on-click-backward": "tz_down",
      "on-scroll-up": "shift_up",
      "on-scroll-down": "shift_down"
    }
  },
  "backlight": {
    "format": "{percent}% {icon}",
    "format-icons": [
      "юОН",
      "юПУ",
      "юПС",
      "юПП",
      "юПО",
      "юПН",
      "юПК",
      "юПИ",
      "юОЫ"
    ]
  },
  "battery": {
    "bat": "BAT0",
    "states": {
      "warning": 30,
      "critical": 20
    },
    "format": "{capacity}% {icon}",
    "format-charging": "ґ▒РЛ {capacity}%",
    "format-plugged": "ґ▒РЛ {capacity}%",
    "format-icons": [
      "яЙД",
      "яЙГ",
      "яЙВ",
      "яЙБ",
      "яЙА"
    ]
  },
  "pulseaudio": {
    "format": "{volume}% {icon} {format_source}",
    "format-bluetooth": "{volume}% {icon} яКФ {format_source}",
    "format-bluetooth-muted": "яЪй {icon} яКФ {format_source}",
    "format-muted": "яЪй {format_source}",
    "format-source": "{volume}% яД░",
    "format-source-muted": "яД▒",
    "format-icons": {
      "headphone": "яАе",
      "hands-free": "яЦР",
      "headset": "яЦР",
      "phone": "яВХ",
      "portable": "яВХ",
      "car": "яЖ╣",
      "default": [
        "яАж",
        "яАз",
        "яАи"
      ]
    },
    "on-click": "pavucontrol"
  },
  "privacy": {
    "icon-spacing": 3,
    "icon-size": 12,
    "transition-duration": 250,
    "modules": [
      {
        "type": "audio-in"
      },
      {
        "type": "screenshare"
      }
    ]
  },
  "power-profiles-daemon": {
    "format": "{icon}",
    "tooltip-format": "Power profile: {profile}\nDriver: {driver}",
    "tooltip": true,
    "format-icons": {
      "default": "яГз",
      "performance": "яГз",
      "balanced": "яЙО",
      "power-saver": "яБм"
    }
  }
}
